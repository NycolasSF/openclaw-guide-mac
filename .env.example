# OpenClaw Mac mini — exemplo de variáveis de ambiente
# Copiar este arquivo para `.env` e preencher os valores reais.
# NUNCA commitar `.env` (já está no .gitignore).

# ───────────────────────────────────────────────────────────
# Token do gateway (shared secret)
# Gerar com:  openssl rand -hex 32
# IMPORTANTE: o mesmo valor precisa estar em
#   ~/openclaw-data/config/openclaw.json → gateway.auth.token
# ───────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=__GENERATE_WITH_openssl_rand_hex_32__

# ───────────────────────────────────────────────────────────
# Imagem Docker (multi-arch — Docker escolhe arm64/amd64)
# Pinar versão em produção:
#   OPENCLAW_IMAGE=openclaw/openclaw:2026.4.22
# ───────────────────────────────────────────────────────────
OPENCLAW_IMAGE=openclaw/openclaw:latest

# ───────────────────────────────────────────────────────────
# Timezone (default: America/Sao_Paulo)
# ───────────────────────────────────────────────────────────
OPENCLAW_TZ=America/Sao_Paulo

# ───────────────────────────────────────────────────────────
# API keys dos providers de LLM
# (deixar vazio se for usar apenas LLM local via Ollama)
# ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ───────────────────────────────────────────────────────────
# Telegram bot (OPCIONAL)
# Criar bot novo no @BotFather, NÃO reusar tokens de outras instâncias
# (Telegram long-poll é exclusivo — se 2 hosts falam com o mesmo bot, brigam)
# ───────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_ID=

# ───────────────────────────────────────────────────────────
# Discord bot (OPCIONAL)
# ───────────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=
